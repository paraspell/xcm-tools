{
  "name": "@paraspell/xcm-analyser",
  "version": "3.0.10",
  "description": "Tool for converting XCM MultiLocation into human readable written format.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "rollup -c",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "runAll": "pnpm compile && pnpm format:write && pnpm lint && pnpm test",
    "runExample": "tsx ./scripts/example.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@codecov/rollup-plugin": "^2.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "tsx": "^4.22.4"
  }
}
