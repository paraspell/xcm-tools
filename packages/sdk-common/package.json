{
  "name": "@paraspell/sdk-common",
  "version": "14.1.0-rc.1",
  "description": "SDK common code for ParaSpell XCM/XCMP tool for developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paraspell/xcm-tools.git",
    "directory": "packages/sdk-common"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "rollup -c",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/plugin-syntax-import-attributes": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@codecov/rollup-plugin": "^2.0.1",
    "@polkadot-api/substrate-bindings": "0.21.0-rc.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/cli-progress": "^3.11.6",
    "@vitest/coverage-v8": "^4.1.9",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1",
    "polkadot-api": "3.0.0-rc.4",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1"
  }
}
