{
  "name": "@paraspell/sdk",
  "version": "13.2.2",
  "description": "SDK for ParaSpell XCM/XCMP tool for developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paraspell/xcm-tools.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "rollup -c",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "runAll": "pnpm compile && pnpm format:write && pnpm lint && pnpm test",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts --sequence.concurrent",
    "test:e2e:chopsticks": "vitest run --config ./vitest.config.chopsticks.e2e.ts"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@paraspell/sdk-core": "workspace:*",
    "@polkadot-labs/hdkd": "^0.0.27",
    "@polkadot-labs/hdkd-helpers": "^0.0.28",
    "viem": "^2.47.6"
  },
  "peerDependencies": {
    "polkadot-api": ">= 2 < 3"
  },
  "devDependencies": {
    "@acala-network/chopsticks": "^1.3.0",
    "@babel/plugin-syntax-import-attributes": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@codecov/rollup-plugin": "^1.9.1",
    "@noble/curves": "^2.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "axios": "^1.14.0",
    "dotenv": "^17.3.1",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1"
  }
}
