{
  "name": "@paraspell/swap",
  "version": "14.1.0-rc.1",
  "description": "Tool for XCM cross-chain asset exchanging across Polkadot and Kusama ecosystems",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "rollup -c",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "runAll": "pnpm compile && pnpm format:write && pnpm lint && pnpm test",
    "updateAssets": "tsx ./scripts/updateAssets.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@acala-network/api": "^6.3.0",
    "@acala-network/app-util": "^4.1.8-14",
    "@acala-network/eth-providers": "^2.10.0",
    "@acala-network/sdk": "4.1.15",
    "@acala-network/sdk-core": "4.1.15",
    "@acala-network/sdk-swap": "4.1.15",
    "@acala-network/sdk-wallet": "4.1.8-14",
    "@crypto-dex-sdk/amm": "^0.1.5",
    "@crypto-dex-sdk/chain": "^0.1.4",
    "@crypto-dex-sdk/currency": "^0.1.5",
    "@crypto-dex-sdk/format": "^0.1.4",
    "@crypto-dex-sdk/math": "^0.1.5",
    "@crypto-dex-sdk/parachains-bifrost": "^0.1.5",
    "@crypto-dex-sdk/token-lists": "^0.1.4",
    "@galacticcouncil/descriptors": "^2.4.0",
    "@galacticcouncil/sdk-next": "^1.3.0",
    "@paraspell/sdk": "workspace:*",
    "@paraspell/sdk-common": "workspace:*",
    "@paraspell/sdk-core": "workspace:*",
    "@paraspell/sdk-pjs": "workspace:*",
    "@polkadot/api": "^16.5.6",
    "@polkadot/api-base": "^16.5.6",
    "@polkadot/types": "^16.5.6",
    "@polkadot/types-codec": "^16.5.6",
    "@polkadot/util": "^14.0.3",
    "@zenlink-types/bifrost": "^1.7.7",
    "axios": "^1.18.1",
    "ethers": "^5.8.0",
    "ethers-v6": "npm:ethers@6.16.0",
    "jsbi": "^4.3.2",
    "lodash-es": "^4.18.1",
    "polkadot-api": "3.0.0-rc.4",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@babel/plugin-syntax-import-attributes": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@codecov/rollup-plugin": "^2.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tsx": "^4.22.4"
  }
}
