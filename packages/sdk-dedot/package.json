{
  "name": "@paraspell/sdk-dedot",
  "version": "13.11.0",
  "description": "Dedot-based SDK for ParaSpell XCM/XCMP tool for developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paraspell/xcm-tools.git",
    "directory": "packages/sdk-dedot"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "rollup -c",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "runAll": "pnpm compile && pnpm format:write && pnpm lint && pnpm test",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts --sequence.concurrent"
  },
  "dependencies": {
    "@paraspell/sdk-common": "workspace:*",
    "@paraspell/sdk-core": "workspace:*"
  },
  "peerDependencies": {
    "dedot": ">= 1.3.0",
    "@polkadot/keyring": ">= 14"
  },
  "devDependencies": {
    "@babel/plugin-syntax-import-attributes": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@codecov/rollup-plugin": "^2.0.1",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1"
  }
}
