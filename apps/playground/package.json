{
  "name": "@paraspell/playground",
  "private": true,
  "version": "13.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "compile": "tsc",
    "preview": "vite preview",
    "lint:check": "eslint src",
    "lint": "eslint --fix src",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "test:e2e": "playwright test",
    "install-polkadot-ext": "cd e2e/extensions/polkadot-ext && yarn && yarn build:chrome",
    "init-polkadot-ext": "git clone https://github.com/polkadot-js/extension e2e/extensions/polkadot-ext && pnpm install-polkadot-ext",
    "init-metamask-ext": "mkdir -p e2e/extensions/metamask-ext/ && cd e2e/extensions/metamask-ext && curl -L -o metamask.zip https://github.com/MetaMask/metamask-extension/releases/download/v12.2.4/metamask-chrome-12.2.4.zip && unzip metamask.zip",
    "init-talisman-ext": "cd e2e/extensions && git clone https://github.com/TalismanSociety/talisman.git talisman-ext && cd talisman-ext && git checkout tags/v3.1.9 && pnpm install && pnpm build:extension",
    "init-e2e": "pnpm init-polkadot-ext && pnpm init-metamask-ext && pnpm init-talisman-ext"
  },
  "dependencies": {
    "@mantine/code-highlight": "^9.0.1",
    "@mantine/core": "^9.0.1",
    "@mantine/form": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@mantine/notifications": "^9.0.1",
    "@mantinex/dev-icons": "^2.0.0",
    "@paraspell/sdk": "workspace:*",
    "@paraspell/sdk-dedot": "workspace:*",
    "@paraspell/sdk-pjs": "workspace:*",
    "@paraspell/xcm-analyser": "workspace:*",
    "@paraspell/swap": "workspace:*",
    "@polkadot/api": "^16.5.6",
    "@polkadot/apps-config": "^0.170.1",
    "@polkadot/extension-dapp": "^0.62.6",
    "@polkadot/extension-inject": "^0.62.6",
    "@polkadot/keyring": "^14.0.3",
    "@polkadot/util": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3",
    "@tabler/icons-react": "^3.41.1",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "dedot": "^1.2.0",
    "ethers": "^6.16.0",
    "highlight.js": "^11.11.1",
    "nuqs": "^2.8.9",
    "polkadot-api": "^2.0.2",
    "react": "^19.2.5",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.5",
    "react-router": "^7.13.2",
    "viem": "^2.47.6",
    "web3": "^4.16.0",
    "web3-validator": "^2.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@metamask/providers": "^22.1.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "path": "^0.12.7",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "url": "^0.11.4",
    "vite": "^8.0.3",
    "vite-plugin-wasm": "^3.6.0"
  }
}
