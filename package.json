{
  "name": "paraspell",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.7.0",
    "netlify-cli": "^26.1.0",
    "prettier": "^3.9.3",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "compile": "turbo run compile",
    "format:check": "turbo run format:check",
    "format:write": "turbo run format:write",
    "lint:check": "turbo run lint:check",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "build": "turbo run build",
    "build:packages": "pnpm --filter \"./packages/*\" build",
    "build:apps": "pnpm --filter \"./apps/*\" build",
    "run:playground": "pnpm --filter playground dev",
    "run:api": "pnpm --filter xcm-api start:dev",
    "run:paraspell-site": "pnpm --filter site dev",
    "run:updateAssets": "pnpm --filter assets updateAssets",
    "run:updateRouterAssets": "pnpm --filter swap updateAssets",
    "run:updatePallets": "pnpm --filter pallets updatePallets"
  },
  "packageManager": "pnpm@11.9.0"
}
